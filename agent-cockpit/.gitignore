# Fichiers à ignorer par Git

# Environnement Python
venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so

# Configuration locale (contient des secrets!)
config/config.yaml

# Logs
logs/
*.log

# Build
dist/
build/
*.spec.bak
*.exe

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Tests
.pytest_cache/
.coverage
htmlcov/
agent-env